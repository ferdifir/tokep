# Production environment.
# Copy this file to `/var/www/tokep/shared/.env.production` on the server.

NODE_ENV="production"

# Required. Use the server PostgreSQL user/database created for this app.
DATABASE_URL="postgresql://tokep_app:replace-with-production-password@127.0.0.1:5432/tokep?schema=public"

# Server media root. Videos live in `konten/video`, photos live in `konten/foto`.
# Deploy symlinks `/var/www/tokep/current/konten` here.
TOKEP_CONTENT_DIR="/var/www/tokep/shared/konten"

# Required. Used to validate Telegram Mini App initData, send admin OTP,
# and notify admin about moderation actions.
TELEGRAM_BOT_TOKEN="replace-with-telegram-bot-token"

# Required. Admin OTP is sent only to this Telegram user/chat id.
ADMIN_TELEGRAM_ID="7764382006"

# Required. Generate a strong random value, for example:
# openssl rand -base64 48
ADMIN_SESSION_SECRET="replace-with-strong-random-secret"
ADMIN_OTP_COOLDOWN_SECONDS="60"

# Required if AI classification/summaries should run in production.
# If empty, the app falls back to deterministic keyword classification.
GROQ_API_KEY="replace-with-groq-api-key"
GROQ_MODEL="openai/gpt-oss-20b"

# Number of unique user reports needed before a service listing becomes flagged.
SERVICE_REPORT_FLAG_THRESHOLD="3"

# Deploy defaults used by scripts when not overridden in the shell.
APP_NAME="tokep"
APP_PORT="3002"
DOMAIN="mandirijayas.my.id"
