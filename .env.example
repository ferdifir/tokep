# PostgreSQL connection string used by Prisma.
# Replace the password, host, port, and database name for your environment.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tokep?schema=public"

# Telegram bot token used to validate Mini App initData on the server.
# Leave empty for local browser development; the app will use the dev fallback user.
TELEGRAM_BOT_TOKEN=""

# Admin OTP is sent only to this Telegram user/chat id.
ADMIN_TELEGRAM_ID="7764382006"

# Random server secret for hashing OTP/session tokens.
ADMIN_SESSION_SECRET="replace-with-random-secret"

GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-20b"
