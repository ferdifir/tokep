# Local development environment.
# Copy this file to `.env` on your local machine.

NODE_ENV="development"

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://tokep_dev:replace-with-local-password@localhost:5432/tokep_dev?schema=public"

# Local media root. Videos live in `konten/video`, photos live in `konten/foto`.
# Relative paths are resolved from the project directory.
TOKEP_CONTENT_DIR="konten"

# Local browser development can use the dummy Telegram user when this is "1".
# Set to "0" if you want to test strict Telegram initData locally.
ALLOW_DEV_TELEGRAM_FALLBACK="1"

# Optional in development. Required in production.
# Also used to send admin notifications for service moderation.
TELEGRAM_BOT_TOKEN=""

# Admin OTP is sent only to this Telegram user/chat id.
ADMIN_TELEGRAM_ID="7764382006"

# Optional in development. Production must use a strong random value.
ADMIN_SESSION_SECRET="tokep-development-secret"
ADMIN_OTP_COOLDOWN_SECONDS="15"

# Optional in development. If empty, service AI uses deterministic keyword fallback.
GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-20b"

# Service moderation defaults.
SERVICE_REPORT_FLAG_THRESHOLD="1"
